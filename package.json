{
	"name": "oviedolab.github.io",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"wasm": "wasm-pack build --release ./src/lib-wasm --target web",
		"dev": "bun run wasm && vite dev",
		"build": "bun run wasm && vite build",
		"preview": "bunx http-server ./build -p 22222 -c 2592000",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"postbuild": "bunx svelte-sitemap"
	},
	"devDependencies": {
		"@aws-crypto/sha256-js": "^5.2.0",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/enhanced-img": "^0.10.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^25.3.0",
		"accessible-colors": "^1.0.8",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"css-element-queries": "^1.2.3",
		"dayjs": "^1.11.19",
		"embla-carousel-svelte": "^8.6.0",
		"hast-util-from-html-isomorphic": "^2.0.0",
		"hast-util-to-html": "^9.0.5",
		"js-yaml": "^4.1.1",
		"mdast-util-to-hast": "^13.2.1",
		"mdast-util-to-string": "^4.0.0",
		"mdsvex": "^0.12.6",
		"mdsvex-relative-images": "^2.0.0",
		"mode-watcher": "^1.1.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"svelte": "^5.51.0",
		"svelte-bricks": "^0.4.1",
		"svelte-check": "^4.3.6",
		"svelte-sitemap": "^3.0.0",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"unist-util-visit": "^5.1.0",
		"vite": "^7.3.1",
		"vite-plugin-wasm-pack": "^0.1.12"
	},
	"dependencies": {}
}
